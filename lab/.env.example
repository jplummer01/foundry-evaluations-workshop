# Full project endpoint: https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=

# Judge model deployment name in this project (AI-assisted evaluators), e.g. gpt-4.1-mini or gpt-5-mini
FOUNDRY_JUDGE_DEPLOYMENT=

# Model deployment the agent itself runs on, e.g. gpt-4.1-mini
FOUNDRY_AGENT_MODEL=

# Set after running create_agent.py (printed on success)
DEMO_AGENT_NAME=demo-weather-agent
DEMO_AGENT_VERSION=1

# Set after running create_agent_gxp.py (generic GxP reference variant)
GXP_AGENT_NAME=demo-sop-agent
GXP_AGENT_VERSION=1

# GxP discipline tracks (see docs/gxp-disciplines.md). Set the NAME/VERSION for
# each after running the matching create_agent_<discipline>.py. All agents can
# coexist in one project; run_cloud_eval.py targets one via --agent-name.
GMP_AGENT_NAME=demo-gmp-agent
GMP_AGENT_VERSION=1
GLP_AGENT_NAME=demo-lab-agent
GLP_AGENT_VERSION=1
GCP_AGENT_NAME=demo-clinical-agent
GCP_AGENT_VERSION=1
GDP_AGENT_NAME=demo-distribution-agent
GDP_AGENT_VERSION=1
